# Use the SERVICE ROLE key (not the anon key) so the Pi can insert alerts
# without being blocked by Row Level Security.
# Keep this key private — never commit it to git or put it in the browser.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdjdWthaHp5a2FvcnFiaGRzcXRyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg0NTgwODEsImV4cCI6MjA5NDAzNDA4MX0.65HF9GxDau2bSfN7BtpLBUGjmjFwmNb0Tc92NCOICyY

