# GuardEye edge device configuration
# Copy this file to ~/edgedevice/.env on the Raspberry Pi
# Then run:  source .env && python proctor_edge.py --source pi --raspi --headless

# ── Supabase credentials ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://gcukahzykaorqbhdsqtr.supabase.co

# Use the SERVICE ROLE key (not the anon key) so the Pi can insert alerts
# without being blocked by Row Level Security.
# Keep this key private — never commit it to git or put it in the browser.
# Get this from: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdjdWthaHp5a2FvcnFiaGRzcXRyIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODQ1ODA4MSwiZXhwIjoyMDk0MDM0MDgxfQ.DM97Q0bPGom4bnLXBT3NiXBt-OmLxmU4XEfzMOuNeAY

# ── Device identity ─────────────────────────────────────────────────────────
# This is what the teacher types into the "Hardware Connection" dialog.
